# === REQUIRED ===

# Get your free Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === PRODUCTION SETTINGS ===

# Generate a long random key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your_secret_key_here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=.onrender.com,localhost

# === PAYSTACK (Payment processing) ===
# Get your keys at https://dashboard.paystack.com/#/settings/developer
# Use sk_test_* for testing, sk_live_* for production
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxx

# Create plans in your Paystack dashboard and paste the plan codes here
PAYSTACK_STARTUP_PLAN_CODE=PLN_xxxxx
PAYSTACK_GROWING_PLAN_CODE=PLN_xxxxx

# === EMAIL (for password reset) ===
# Use console backend for local dev, SMTP for production
# Gmail: smtp.gmail.com, your@gmail.com, app-password
# SendGrid: smtp.sendgrid.net, apikey, SG.xxxxx
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=finanTrace <noreply@finantrace.app>

# === DATABASE (PostgreSQL - required in production) ===
# Option A: Single DATABASE_URL (recommended for Render/Supabase)
# Supabase: Project Settings > Database > Connection string (URI)
# DATABASE_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres?sslmode=require

# Option B: Individual settings (for local Docker)
USE_SQLITE=False
DB_NAME=finantrace
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# === SITE CONFIGURATION (Required for Google OAuth) ===
# Must match your actual domain for allauth callback URLs to work
SITE_DOMAIN=finantrace.onrender.com
SITE_NAME=finanTrace

# === GOOGLE OAUTH (Required for login) ===
# Create credentials at https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID for Web application
# Add authorized redirect URI: https://finantrace.onrender.com/accounts/google/login/callback/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_SECRET_KEY=your_google_client_secret

# === PRODUCTION SECURITY ===
# Comma-separated list of trusted origins for CSRF
CSRF_TRUSTED_ORIGINS=https://finantrace.onrender.com,https://your-custom-domain.com
